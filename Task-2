import { useState, useEffect } from "react";

function useCurrentTime() {
  const [time, setTime] = useState(new Date());

  useEffect(() => {
    const intervalId = setInterval(() => {
      setTime(new Date());
    }, 1000);

    return () => clearInterval(intervalId); // cleanup on unmount
  }, []);

  return time;
}

function Clock() {
  const time = useCurrentTime();
  return <h2>{time.toLocaleTimeString()}</h2>;
}



import { useState, useEffect } from "react";

function useTrendingMovies(apiKey) {
  const [data, setData] = useState(null);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState(null);

  useEffect(() => {
    let isCancelled = false;

    async function fetchMovies() {
      setLoading(true);
      setError(null);
      try {
        const res = await fetch(
          `https://api.themoviedb.org/3/trending/movie/day?api_key=${apiKey}`
        );
        if (!res.ok) throw new Error(`Status ${res.status}`);
        const json = await res.json();
        if (!isCancelled) setData(json.results);
      } catch (err) {
        if (!isCancelled) setError(err.message);
      } finally {
        if (!isCancelled) setLoading(false);
      }
    }

    fetchMovies();
    return () => { isCancelled = true; };
  }, [apiKey]);

  return { data, loading, error };
}

function MoviesList({ apiKey }) {
  const { data: movies, loading, error } = useTrendingMovies(apiKey);

  if (loading) return <p>Loading trending movies...</p>;
  if (error) return <p>Error: {error}</p>;

  return (
    <ul>
      {movies.map(movie => (
        <li key={movie.id}>{movie.title}</li>
      ))}
    </ul>
  );
}


import { useState } from "react";

function useLikeButton(initialLikes = 0) {
  const [liked, setLiked] = useState(false);
  const [likeCount, setLikeCount] = useState(initialLikes);

  const toggleLike = () => {
    setLiked(prev => !prev);
    setLikeCount(prev => (liked ? prev - 1 : prev + 1));
  };

  return { liked, likeCount, toggleLike };
}

function PostCard({ post }) {
  const { liked, likeCount, toggleLike } = useLikeButton(post.initialLikes);

  return (
    <div className="post-card">
      <p>{post.caption}</p>
      <button onClick={toggleLike}>
        {liked ? "❤️ Liked" : "🤍 Like"}
      </button>
      <span> {likeCount} likes</span>
    </div>
  );
}

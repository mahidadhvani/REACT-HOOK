import { initializeApp } from "firebase/app";
import { getFirestore } from "firebase/firestore";

const firebaseConfig = {
  apiKey: process.env.REACT_APP_FIREBASE_API_KEY,
  authDomain: process.env.REACT_APP_FIREBASE_AUTH_DOMAIN,
  projectId: process.env.REACT_APP_FIREBASE_PROJECT_ID,
  storageBucket: process.env.REACT_APP_FIREBASE_STORAGE_BUCKET,
  messagingSenderId: process.env.REACT_APP_FIREBASE_MESSAGING_SENDER_ID,
  appId: process.env.REACT_APP_FIREBASE_APP_ID,
};

const app = initializeApp(firebaseConfig);
export const db = getFirestore(app); // exported once, imported wherever Firestore is used

export default app;



import { useState } from "react";
import { collection, addDoc } from "firebase/firestore";
import { db } from "./firebase";

function AddRestaurantForm() {
  const [name, setName] = useState("");
  const [cuisine, setCuisine] = useState("");
  const [error, setError] = useState(null);

  const handleSubmit = async (e) => {
    e.preventDefault();
    if (!name.trim() || !cuisine.trim()) return;

    try {
      // addDoc creates a new document with an auto-generated ID
      // inside the 'restaurants' collection.
      await addDoc(collection(db, "restaurants"), {
        name,
        cuisine,
      });
      setName("");
      setCuisine("");
    } catch (err) {
      setError(err.message);
    }
  };

  return (
    <form onSubmit={handleSubmit}>
      <h2>Add Restaurant</h2>
      <input
        type="text"
        placeholder="Restaurant name"
        value={name}
        onChange={(e) => setName(e.target.value)}
        required
      />
      <input
        type="text"
        placeholder="Cuisine (e.g. Italian)"
        value={cuisine}
        onChange={(e) => setCuisine(e.target.value)}
        required
      />
      <button type="submit">Add Restaurant</button>
      {error && <p style={{ color: "red" }}>{error}</p>}
    </form>
  );
}

export default AddRestaurantForm;

import { useState } from "react";
import { doc, updateDoc } from "firebase/firestore";
import { db } from "./firebase";

function PlaylistEditor({ playlistId }) {
  const [newName, setNewName] = useState("");
  const [status, setStatus] = useState(null);

  const handleUpdate = async (e) => {
    e.preventDefault();
    if (!newName.trim()) return;

    try {
      // doc() points to a specific document by collection + ID;
      // updateDoc() only changes the fields you pass in, leaving
      // the rest of the document untouched.
      const playlistRef = doc(db, "playlists", playlistId);
      await updateDoc(playlistRef, { name: newName });
      setStatus("Playlist updated!");
      setNewName("");
    } catch (err) {



      setStatus(`Error: ${err.message}`);
    }
  };

  return (
    <form onSubmit={handleUpdate}>
      <h3>Edit Playlist</h3>
      <input
        type="text"
        placeholder="New playlist name"
        value={newName}
        onChange={(e) => setNewName(e.target.value)}
        required
      />
      <button type="submit">Save</button>
      {status && <p>{status}</p>}
    </form>
  );
}

export default PlaylistEditor;
